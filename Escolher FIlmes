class Filmes():
    def __init__(self, nome, genero):
        self.nome = nome
        self.genero = genero

    def mostrar_filmes(self):
        print(f"Filmes: {self.nome} | Gênero: {self.genero}")

filme1 = Filmes("Godzilla", "Ação")
filme2 = Filmes("Vingadores", "Ação")
filme3 = Filmes("Titanic", "Drama")
filme4 = Filmes("A Culpa é das Estrelas", "Romance")

lista_filmes = [filme1, filme2, filme3, filme4]


for filmes in lista_filmes:
    filmes.mostrar_filmes()
